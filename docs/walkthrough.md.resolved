## 🏗️ CẤU TRÚC FILE ĐỀ XUẤT

```python
# strategy_engine.py
# Ước ~500–600 dòng (production-ready, type hints đầy đủ)

from dataclasses import dataclass, field
from datetime import datetime, timezone
from typing import Optional
import logging
import numpy as np

# Data containers (FVGZone, PriceLevel, SwingPoints, MarketBias, SignalResult)
# ...

class StrategyEngine:
    # Constants mặc định — override bởi config dict
    DEFAULT_SWING_LOOKBACK        = 3
    DEFAULT_FVG_MAX_SIZE          = 20
    DEFAULT_FVG_TTL_CANDLES       = 48    # 48 nến M15 = 12 giờ
    DEFAULT_PINBAR_WICK_RATIO     = 0.60  # lower/upper wick >= 60% total range
    DEFAULT_VSA_CLIMAX_MULTIPLIER = 1.5   # volume >= 1.5x session mean
    DEFAULT_MIN_SIGNAL_SCORE      = 0.55  # Composite score tối thiểu để ra signal
    DEFAULT_FVG_BUFFER_PIPS       = 2     # buffer khi tính SL so với FVG boundary

    def __init__(self, config: dict, logger: logging.Logger): ...
    def analyze(self, h1_data, m15_data, m5_data, current_time) -> SignalResult: ...
    def detect_swing_points(self, h1_data: np.ndarray) -> SwingPoints: ...
    def detect_market_structure(self, h1_data: np.ndarray, swings: SwingPoints) -> MarketBias: ...
    def scan_fvg(self, m15_data: np.ndarray) -> list[FVGZone]: ...
    def update_fvg_pool(self, new_fvgs: list[FVGZone], current_price: float) -> None: ...
    def get_active_fvgs(self, bias: MarketBias) -> list[FVGZone]: ...
    def check_price_in_fvg(self, m5_data: np.ndarray, active_fvgs: list[FVGZone]) -> Optional[FVGZone]: ...
    def validate_pinbar(self, m5_data: np.ndarray, direction: str) -> tuple[bool, float]: ...
    def validate_vsa(self, m5_data: np.ndarray, current_time: datetime) -> tuple[bool, float]: ...

    # Private helpers
    def _composite_score(self, pin_score, vsa_score, bias, fvg) -> float: ...
    def _calculate_entry_sl(self, candle, direction, fvg) -> tuple[float, float]: ...
    def _get_session(self, utc_hour: int) -> str: ...
```

