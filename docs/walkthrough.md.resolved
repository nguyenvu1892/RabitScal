## ⚙️ THIẾT KẾ CLASS `BotOrchestrator` (OOP Architecture)

```
class BotOrchestrator
│
├─ __init__(config_path: str)
│       Đọc config tổng hợp (main_config.json)
│       Khởi tạo logger (RotatingFileHandler → logs/system.log)
│       Khởi tạo 3 module core:
│           self.pipeline  = DataPipeline(cfg, logger)
│           self.strategy  = StrategyEngine(cfg, logger)
│           self.risk      = RiskManager(cfg, logger, state_path, config_path)
│           self.executor  = OrderManager(cfg, logger)     # execution.py
│       Internal state:
│           self.state          = BotState.IDLE
│           self.open_trade     = None    # TradeInfo | None
│           self.last_signal    = None    # SignalResult | None
│           self.daily_reset_done: bool = False
│
├─ start() → None              [Main Entry Point]
│       self.pipeline.start()      ← kết nối MT5, spawn heartbeat
│       self._run_loop()           ← bắt đầu vòng lặp chính
│
├─ stop() → None               [Graceful Shutdown]
│       self._running = False
│       self.pipeline.stop()
│       log INFO: "BotOrchestrator stopped"
│
├─ ─────────────── MAIN LOOP ───────────────
│
├─ _run_loop() → None
│       while self._running:
│           try:
│               self._check_daily_reset()
│               self._dispatch_state()
│           except KeyboardInterrupt:
│               self.stop()
│               break
│           except Exception as e:
│               log CRITICAL: f"Unhandled error in state={self.state}: {e}"
│               self._transition(BotState.IDLE)
│           time.sleep(LOOP_INTERVAL_SEC)     # 1 giây giữa mỗi tick
│
├─ _dispatch_state() → None
│       Router: gọi handler tương ứng với state hiện tại
│       {
│           BotState.IDLE:          self._state_idle()
│           BotState.SCANNING:      self._state_scanning()
│           BotState.SIGNAL_FOUND:  self._state_signal_found()
│           BotState.PENDING_ORDER: self._state_pending_order()
│           BotState.IN_TRADE:      self._state_in_trade()
│           BotState.CLOSING:       self._state_closing()
│       }
│
├─ ─────────────── STATE HANDLERS ───────────────
│
├─ _state_idle() → None
│       Điều kiện chuyển sang SCANNING:
│           1. data_pipeline.is_session_active()       → có session London/NY?
│           2. risk_manager.is_active()                → bot không bị cooldown/pause/halt?
│           3. self.open_trade is None                 → không có lệnh đang mở (đảm bảo)
│       Nếu tất cả True → _transition(SCANNING)
│       Nếu không → log DEBUG + sleep chờ
│       Nếu 00:00 UTC → _check_daily_reset()
│
├─ _state_scanning() → None
│       try:
│           data = data_pipeline.fetch_all()                 ← H1/M15/M5 data
│           if data is None or quality_score < MIN_QUALITY:
│               _transition(IDLE)
│               return
│
│           signal = strategy.analyze(
│               h1_data=data["H1"], m15_data=data["M15"],
│               m5_data=data["M5"], current_time=utcnow()
│           )
│
│           if signal.has_signal:
│               self.last_signal = signal
│               _transition(SIGNAL_FOUND)
│           else:
│               _transition(IDLE)     ← về IDLE, chờ nến M5 tiếp theo
│       except Exception as e:
│           log ERROR: f"[SCANNING] {e}"
│           _transition(IDLE)
│
├─ _state_signal_found() → None
│       signal = self.last_signal
│
│       # Double-check risk trước khi tiến hành
│       if not risk_manager.is_active():
│           log WARNING: "Signal found but bot not active"
│           _transition(IDLE)
│           return
│
│       account = mt5.account_info()
│       balance = account.balance
│       atr     = _get_atr14(data["M5"])
│
│       sl_pips = risk_mgr.calculate_sl_distance(atr, signal.direction)
│       lot     = risk_mgr.calculate_lot_size(balance, atr, sl_pips)
│       ok, reason = risk_mgr.validate_trade(balance, lot, sl_pips)
│
│       if not ok:
│           log WARNING: f"[SIGNAL_FOUND] Trade rejected: {reason}"
│           _transition(IDLE)
│           return
│
│       # Lưu thông tin order sẽ gửi
│       self.open_trade = TradeInfo(
│           signal    = signal,
│           lot       = lot,
│           sl_pips   = sl_pips,
│           order_time= utcnow(),
│       )
│       _transition(PENDING_ORDER)
│
├─ _state_pending_order() → None
│       trade = self.open_trade
│       TIMEOUT_SEC = 30
│
│       result = executor.send_order(
│           symbol    = SYMBOL,
│           direction = trade.signal.direction,
│           lot       = trade.lot,
│           sl_price  = trade.signal.sl_price,
│           comment   = f"Rabit_{trade.signal.score:.3f}",
│       )
│
│       if result.success:
│           trade.ticket      = result.ticket
│           trade.fill_price  = result.fill_price
│           trade.fill_time   = result.fill_time
│           log INFO: f"[PENDING_ORDER] FILLED | ticket={result.ticket}"
│           _transition(IN_TRADE)
│       else:
│           log WARNING: f"[PENDING_ORDER] FAILED | reason={result.error}"
│           self.open_trade = None
│           _transition(IDLE)
│
├─ _state_in_trade() → None
│       ⚡ CRITICAL: Bot KHÔNG được scan signal mới ở state này.
│       Chỉ làm 2 việc:
│
│       [1] Floating Drawdown Monitor (gọi mỗi tick):
│           account = mt5.account_info()
│           safe = risk_mgr.check_floating_drawdown(account.equity)
│           if not safe:
│               log CRITICAL: "Floating DD breached → Market Close All"
│               _close_all_orders_market()
│               _transition(CLOSING)
│               return
│
│       [2] Check SL/TP Hit (MT5 position monitor):
│           positions = mt5.positions_get(ticket=self.open_trade.ticket)
│           if positions is None or len(positions) == 0:
│               # Lệnh đã đóng (SL/TP hit hoặc manual close)
│               _transition(CLOSING)
│
│       # Nếu lệnh vẫn mở → ở lại IN_TRADE, không làm gì thêm
│
├─ _state_closing() → None
│       ticket = self.open_trade.ticket if self.open_trade else None
│
│       if ticket:
│           # Lấy lịch sử lệnh từ MT5
│           history = mt5.history_deals_get(position=ticket)
│           if history:
│               pnl          = sum(d.profit for d in history)
│               close_reason = _parse_close_reason(history[-1])
│
│               result = TradeResult(
│                   ticket       = ticket,
│                   pnl          = pnl,
│                   close_reason = close_reason,
│                   timestamp    = utcnow(),
│               )
│
│               # Báo cáo cho RiskManager → cập nhật safety net
│               account = mt5.account_info()
│               risk_mgr.on_trade_closed(result, account.balance)
│
│               log INFO: f"[CLOSING] ticket={ticket} | pnl={pnl:+.4f} | reason={close_reason}"
│
│       self.open_trade = None
│       self.last_signal = None
│       _transition(IDLE)
│
├─ ─────────────── DAILY RESET ───────────────
│
├─ _check_daily_reset() → None
│       now = utcnow()
│       if now.hour == 0 and now.minute == 0 and not self.daily_reset_done:
│           account = mt5.account_info()
│           risk_mgr.reset_daily(account.balance)
│           self.daily_reset_done = True
│           log INFO: f"[DAILY_RESET] balance={account.balance:.2f}"
│       elif now.hour != 0:
│           self.daily_reset_done = False    # Reset flag cho ngày tiếp theo
│
├─ ─────────────── HELPERS ───────────────
│
├─ _transition(new_state: BotState) → None
│       old = self.state
│       self.state = new_state
│       log INFO: f"[STATE] {old.name} → {new_state.name}"
│
├─ _close_all_orders_market() → None
│       positions = mt5.positions_get(symbol=SYMBOL)
│       for pos in (positions or []):
│           executor.close_order_market(pos.ticket, pos.volume, pos.type)
│       log CRITICAL: "[EMERGENCY] All positions market-closed"
│
├─ _get_atr14(m5_data: np.ndarray) → float
│       Tính ATR(14) trực tiếp từ numpy array m5_data[:-2] (chỉ nến đã đóng)
│       Dùng True Range formula: max(H-L, |H-prev_C|, |L-prev_C|)
│       return mean(true_ranges[-14:])
│
└─ _parse_close_reason(deal) → str
        Đọc deal.reason từ MT5 history:
            DEAL_REASON_SL     → "SL"
            DEAL_REASON_TP     → "TP"
            DEAL_REASON_CLIENT → "MANUAL"
            else               → f"MT5_{deal.reason}"
```

