## 📐 CẤU TRÚC FILE & CONFIG

### `risk_manager.py` — Cấu trúc đề xuất

```python
# risk_manager.py
# Khoảng ~300 dòng (production-ready, type hints)

from dataclasses import dataclass, field
from datetime import datetime, timedelta, timezone
from math import floor
from typing import Optional
import logging
import MetaTrader5 as mt5

@dataclass
class TradeResult:
    ticket:       int
    pnl:          float
    close_reason: str
    timestamp:    datetime

class RiskManager:
    # Constants — có thể override qua config dict
    DEFAULT_DAILY_DD_LIMIT       = 0.06   # 6%
    DEFAULT_STREAK_LIMIT         = 3
    DEFAULT_BALANCE_FLOOR_PCT    = 0.50   # 50% initial
    DEFAULT_MAX_RISK_PER_TRADE   = 0.03   # 3%
    DEFAULT_ATR_MULTIPLIER       = 1.5
    
    def __init__(self, config: dict, initial_balance: float, logger: logging.Logger): ...
    def calculate_lot_size(self, balance, atr_value, sl_pips) -> float: ...
    def calculate_sl_distance(self, atr_value, direction) -> float: ...
    def validate_trade(self, balance, lot_size, sl_pips) -> tuple[bool, str]: ...
    def on_trade_closed(self, result: TradeResult) -> None: ...
    def is_active(self) -> bool: ...
    def reset_daily(self, new_balance: float) -> None: ...
    def get_status_report(self) -> dict: ...
    def manual_reset(self, confirmed: bool) -> bool: ...   # Chỉ dùng cho HALTED state
    
    # Private helpers
    def _floor_lot(self, raw_lot, volume_step) -> float: ...
    def _get_pip_value_per_lot(self, symbol) -> float: ...
    def _update_streak(self, pnl) -> None: ...
    def _check_daily_drawdown(self, current_balance) -> None: ...
    def _check_balance_floor(self, current_balance) -> None: ...
    def _trigger_cooldown(self, reason) -> None: ...
    def _trigger_pause(self, reason) -> None: ...
    def _trigger_halt(self, reason) -> None: ...
```

