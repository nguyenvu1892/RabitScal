## 📦 DATA CONTAINERS

```python
from enum import Enum, auto
from dataclasses import dataclass, field
from datetime import datetime
from typing import Optional

class BotState(Enum):
    IDLE          = auto()
    SCANNING      = auto()
    SIGNAL_FOUND  = auto()
    PENDING_ORDER = auto()
    IN_TRADE      = auto()
    CLOSING       = auto()


@dataclass
class TradeInfo:
    """Thông tin lệnh đang mở — maintained trong open_trade."""
    signal:      "SignalResult"      # SignalResult từ strategy_engine
    lot:         float
    sl_pips:     float
    order_time:  datetime
    ticket:      int       = 0
    fill_price:  float     = 0.0
    fill_time:   Optional[datetime] = None
    close_reason: str      = ""
    pnl:          float    = 0.0
```

